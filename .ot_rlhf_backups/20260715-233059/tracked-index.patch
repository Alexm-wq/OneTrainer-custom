+            (batch_size,),
+            float(alpha),
+            dtype=torch.float32,
+            device=device,
+        )
+        beta_tensor = torch.full(
+            (batch_size,),
+            float(beta),
+            dtype=torch.float32,
+            device=device,
+        )
+
