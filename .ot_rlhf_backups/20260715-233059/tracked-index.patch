diff --git a/modules/ui/RLHFTabController.py b/modules/ui/RLHFTabController.py
new file mode 100644
index 00000000..cc98a572
--- /dev/null
+++ b/modules/ui/RLHFTabController.py
@@ -0,0 +1,289 @@
+import json
+import os
+
+from PySide6.QtWidgets import QApplication, QMessageBox
+
+from modules.util.config.ConceptConfig import ConceptConfig
+from modules.util.config.TrainConfig import TrainConfig
+from modules.util.dpo_bucket_analysis_util import analyze_concept, parse_target_resolutions, quantization_for_model
+from modules.util.dpo_curation_util import (
+    check_dpo_pairs,
+    correct_all_captions_to_chosen,
+    dpo_pair_key,
+    find_caption_mismatches,
+    fix_multiline_captions,
+    remove_finalized_pair,
+    scan_finalized_pairs,
+)
+from modules.util.dpo_pattern_util import dpo_concept_pattern_dirs
+from modules.util.path_util import supported_image_extensions
+
+
+class RLHFTabController:
+    def __init__(self, train_config: TrainConfig):
+        self.train_config = train_config
+        self.parent_widget = None
+
+    def set_parent(self, parent_widget):
+        self.parent_widget = parent_widget
+
+    def _parent(self):
+        return self.parent_widget or QApplication.activeWindow()
+
+    def _info(self, title: str, text: str, details: str | None = None):
+        box = QMessageBox(self._parent())
+        box.setIcon(QMessageBox.Information)
+        box.setWindowTitle(title)
+        box.setText(text)
+        if details:
+            box.setDetailedText(details)
+        box.exec()
+
+    def _error(self, title: str, text: str):
+        QMessageBox.critical(self._parent(), title, text)
+
+    def _ask(self, title: str, text: str) -> bool:
+        return QMessageBox.question(
+            self._parent(),
+            title,
+            text,
+            QMessageBox.Yes | QMessageBox.No,
+            QMessageBox.No,
+        ) == QMessageBox.Yes
+
+    def _load_concepts(self):
+        concepts = self.train_config.concepts
+
+        if concepts is None:
+            concept_file = self.train_config.concept_file_name
+            if not concept_file or not os.path.isfile(concept_file):
+                raise RuntimeError("No concepts configured. Set up concepts in the Concepts tab first.")
+
+            with open(concept_file, "r", encoding="utf-8") as f:
+                concepts = [ConceptConfig.default_values().from_dict(c) for c in json.load(f)]
+
+        return concepts
+
+    def _load_concept_pairs(self) -> list[tuple[str, str]]:
+        concept_pairs = dpo_concept_pattern_dirs(self._load_concepts())
+        if not concept_pairs:
+            raise RuntimeError(
+                "No DPO concepts found. Set chosen/rejected patterns on a concept in the Concepts tab."
+            )
+        return concept_pairs
+
+    def _remove_strays(self, concept_pairs: list[tuple[str, str]], result: dict) -> int:
+        exts = supported_image_extensions()
+        removed = 0
+
+        for i, (chosen_path, rejected_path) in enumerate(concept_pairs):
+            pair_info = result["pairs"][i]
+            if pair_info.get("chosen_stray", 0) == 0 and pair_info.get("rejected_stray", 0) == 0:
+                continue
+
+            chosen_keys: dict[str, str] = {}
+            rejected_keys: dict[str, str] = {}
+
+            for root, _dirs, files in os.walk(chosen_path):
+                for fname in files:
+                    ext = os.path.splitext(fname)[1].lower()
+                    if ext in exts:
+                        full = os.path.join(root, fname)
+                        chosen_keys[dpo_pair_key(full, chosen_path)] = full
+
+            for root, _dirs, files in os.walk(rejected_path):
+                for fname in files:
+                    ext = os.path.splitext(fname)[1].lower()
+                    if ext in exts:
+                        full = os.path.join(root, fname)
+                        rejected_keys[dpo_pair_key(full, rejected_path)] = full
+
+            matched = set(chosen_keys) & set(rejected_keys)
+
+            for key, path in chosen_keys.items():
+                if key not in matched:
+                    remove_finalized_pair(path, None)
+                    removed += 1
+
+            for key, path in rejected_keys.items():
+                if key not in matched:
+                    remove_finalized_pair(None, path)
+                    removed += 1
+
+        return removed
+
+    def check_pairs(self):
+        try:
+            concept_pairs = self._load_concept_pairs()
+            result = check_dpo_pairs(concept_pairs)
+        except Exception as ex:
+            self._error("Check Pairs Error", str(ex))
+            return
+
+        total_matched = int(result.get("total_matched", 0))
+        total_chosen_stray = int(result.get("total_chosen_stray", 0))
+        total_rejected_stray = int(result.get("total_rejected_stray", 0))
+        multiline = int(result.get("multiline_captions", 0))
+        total_strays = total_chosen_stray + total_rejected_stray
+
+        lines = [
+            f"Matched pairs: {total_matched}",
+            f"Chosen strays: {total_chosen_stray}",
+            f"Rejected strays: {total_rejected_stray}",
+            f"Multiline captions: {multiline}",
+        ]
+
+        if result.get("format_stats"):
+            fmt = ", ".join(f"{ext}: {count}" for ext, count in sorted(result["format_stats"].items()))
+            lines.append(f"Formats: {fmt}")
+
+        details = []
+        for pair_info in result.get("pairs", []):
+            details.append("--- Pair ---")
+            details.append(f"Chosen: {pair_info.get('chosen_path')}")
+            details.append(f"Rejected: {pair_info.get('rejected_path')}")
+            details.append(
+                f"Matched: {pair_info.get('matched', 0)}, "
+                f"Chosen stray: {pair_info.get('chosen_stray', 0)}, "
+                f"Rejected stray: {pair_info.get('rejected_stray', 0)}"
+            )
+
+        self._info("Check Pairs Results", "\n".join(lines), "\n".join(details))
+
+        if total_strays > 0 and self._ask(
+            "Remove Strays?",
+            f"Found {total_strays} stray file(s) with no matching pair.\n\n"
+            "Remove them and their caption files?",
+        ):
+            removed = self._remove_strays(concept_pairs, result)
+            self._info("Strays Removed", f"Removed {removed} stray file(s) and their captions.")
+
+        if multiline > 0 and self._ask(
+            "Fix Multiline Captions?",
+            f"Found {multiline} caption file(s) with newlines.\n\n"
+            "Flatten them to single-line captions?",
+        ):
+            fixed = fix_multiline_captions(concept_pairs)
+            self._info("Captions Fixed", f"Flattened {fixed} caption file(s) to single lines.")
+
+        try:
+            mismatches = find_caption_mismatches(concept_pairs)
+        except Exception as ex:
+            self._error("Caption Mismatch Error", str(ex))
+            return
+
+        if mismatches:
+            details = []
+            for m in mismatches[:200]:
+                details.append("--- Caption mismatch ---")
+                details.append(f"Chosen: {m.get('chosen_image')}")
+                details.append(f"Rejected: {m.get('rejected_image')}")
+                details.append(f"Chosen caption: {m.get('chosen_caption', '')[:500]}")
+                details.append(f"Rejected caption: {m.get('rejected_caption', '')[:500]}")
+
+            self._info(
+                "Caption Mismatches",
+                f"Found {len(mismatches)} chosen/rejected caption mismatch(es).",
+                "\n".join(details),
+            )
+
+            if self._ask(
+                "Correct Rejected Captions?",
+                "Overwrite every rejected caption with its matched chosen caption?",
+            ):
+                corrected = correct_all_captions_to_chosen(mismatches)
+                self._info(
+                    "Captions Corrected",
+                    f"Overwrote {corrected} rejected caption file(s) with the chosen caption.",
+                )
+
+    def review_pairs(self):
+        try:
+            concept_pairs = self._load_concept_pairs()
+            pairs = scan_finalized_pairs(concept_pairs)
+        except Exception as ex:
+            self._error("Review Pairs Error", str(ex))
+            return
+
+        total = len(pairs)
+        orphans = [p for p in pairs if p.get("is_orphan")]
+        matched = total - len(orphans)
+
+        details = []
+        for p in pairs[:300]:
+            details.append("--- Pair ---")
+            details.append(f"Key: {p.get('key')}")
+            details.append(f"Chosen: {p.get('chosen_path')}")
+            details.append(f"Rejected: {p.get('rejected_path')}")
+            details.append(f"Orphan: {p.get('is_orphan')}")
+
+        self._info(
+            "DPO Pair Review",
+            f"Total pair keys: {total}\nMatched: {matched}\nOrphans: {len(orphans)}",
+            "\n".join(details),
+        )
+
+        if orphans and self._ask(
+            "Remove Orphans?",
+            f"Found {len(orphans)} orphan pair key(s).\n\nRemove orphan images and sidecar captions?",
+        ):
+            removed = 0
+            for p in orphans:
+                remove_finalized_pair(p.get("chosen_path"), p.get("rejected_path"))
+                removed += 1
+            self._info("Orphans Removed", f"Removed {removed} orphan pair key(s).")
+
+    def bucket_analysis(self):
+        try:
+            concept_pairs = self._load_concept_pairs()
+            target_resolutions = parse_target_resolutions(str(self.train_config.resolution))
+            if not target_resolutions:
+                raise RuntimeError(
+                    f"Could not parse target resolutions from TrainConfig.resolution='{self.train_config.resolution}'."
+                )
+
+            batch_size = int(self.train_config.batch_size)
+            grad_accum = int(getattr(self.train_config, "gradient_accumulation_steps", 1))
+            effective_batch = max(1, batch_size * grad_accum)
+            quantization = quantization_for_model(str(self.train_config.model_type))
+
+            lines = [
+                f"Target resolutions: {target_resolutions}",
+                f"Batch size: {batch_size}",
+                f"Gradient accumulation: {grad_accum}",
+                f"Effective bucket multiple: {effective_batch}",
+                f"Quantization: {quantization}",
+                "",
+            ]
+
+            details = []
+            for chosen_path, rejected_path in concept_pairs:
+                for label, path in (("chosen", chosen_path), ("rejected", rejected_path)):
+                    result = analyze_concept(
+                        path,
+                        effective_batch,
+                        target_resolutions,
+                        quantization,
+                        include_subdirectories=True,
+                    )
+                    lines.append(f"{label}: {path}")
+                    lines.append(f"  scanned={result['scanned']} unreadable={result['unreadable']}")
+
+                    details.append(f"=== {label}: {path} ===")
+                    for target in result["targets"]:
+                        details.append(
+                            f"target={target['target']} total={target['total_pairs']} "
+                            f"drops={target['total_drops']} add={target['total_add']} "
+                            f"remove={target['total_remove']}"
+                        )
+                        for row in target["buckets"][:50]:
+                            details.append(
+                                f"  {row['w']}x{row['h']} {row['aspect_label']}: "
+                                f"count={row['count']} drops={row['drops']} "
+                                f"add={row['add']} remove={row['remove']}"
+                            )
+                    details.append("")
+
+            self._info("DPO Bucket Analysis", "\n".join(lines[:80]), "\n".join(details))
+        except Exception as ex:
+            self._error("DPO Bucket Analysis Error", str(ex))
